# Local environment for Expo dev / Xcode / Android Studio builds.
# Copy this file to `.env` (next to it, same folder) and fill in the values.
# `.env` is gitignored, so each machine needs its own copy.
#
# IMPORTANT: these are inlined into the JS bundle at build time by the Expo
# babel plugin (the `EXPO_PUBLIC_*` prefix is the trigger). A missing key
# means the corresponding feature returns null / [] silently — the symptom
# you'll see is "no transactions found" on scan, or voice input that flashes
# the recognized text then clears.
#
# After changing this file you MUST do a clean rebuild:
#   - Xcode:  Product → Clean Build Folder (Shift+Cmd+K), then Build (Cmd+R)
#   - Metro:  npx expo start --clear
#
# These values are also stored in EAS env (preview / production envs), so
# `eas build` does NOT depend on this file. Only local builds do.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_SENTRY_DSN=
