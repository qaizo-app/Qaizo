{
  "expo": {
    "name": "Qaizo",
    "slug": "qaizo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#151a28"
    },
    "icon": "./assets/images/icon.png",
    "scheme": "qaizo",
    "android": {
      "package": "com.qaizo.app",
      "versionCode": 16,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.qaizo.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Qaizo to recognize your speech",
        "NSMicrophoneUsageDescription": "Allow Qaizo to access your microphone for voice input"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-localization",
      "./plugins/withTransparentAutofill",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "Allow Qaizo to access your microphone for voice input",
          "speechRecognitionPermission": "Allow Qaizo to recognize your speech"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Qaizo to access your photos for receipt scanning",
          "cameraPermission": "Allow Qaizo to take photos of receipts"
        }
      ],
      "react-native-edge-to-edge",
      "./plugins/withResizeableActivity",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native/expo",
        {
          "organization": "qaizo",
          "project": "qaizo"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "912cb02d-8765-41cf-9557-99d035d52189"
      }
    },
    "owner": "qaizo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/912cb02d-8765-41cf-9557-99d035d52189"
    }
  }
}
