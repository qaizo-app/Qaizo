{
  "expo": {
    "name": "Qaizo",
    "slug": "qaizo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#151a28"
    },
    "icon": "./assets/images/icon.png",
    "scheme": "qaizo",
    "android": {
      "package": "com.qaizo.app",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.qaizo.app"
    },
    "plugins": [
      "expo-localization",
      "./plugins/withTransparentAutofill",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "@jamsch/expo-speech-recognition",
        {
          "microphonePermission": "Allow Qaizo to access your microphone for voice input",
          "speechRecognitionPermission": "Allow Qaizo to recognize your speech"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Qaizo to access your photos for receipt scanning",
          "cameraPermission": "Allow Qaizo to take photos of receipts"
        }
      ],
      "react-native-edge-to-edge",
      "./plugins/withResizeableActivity",
      "@react-native-google-signin/google-signin",
      [
        "@sentry/react-native",
        {
          "uploadSourceMaps": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "912cb02d-8765-41cf-9557-99d035d52189"
      }
    },
    "owner": "qaizo"
  }
}
